public void display(){
        System.out.println("Array: " + Arrays.toString(queArray).replace(",","").replace("[","").replace("]",""));

        System.out.printf("Queue: ");

        for(int i=0; i<nItems; i++){
            int index = front + i;
            System.out.print(queArray[index] + " ");
        }
        System.out.println();
    }